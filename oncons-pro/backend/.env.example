ENVIRONMENT=development
DATABASE_URL=sqlite:///./oncons.db
JWT_SECRET=change-this-before-production
JWT_EXP_MIN=60
REFRESH_TOKEN_DAYS=30
FRONTEND_URL=http://localhost:5500
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:5600,http://127.0.0.1:5500,http://127.0.0.1:5600

# Best production database choice:
# Use managed PostgreSQL from Supabase, Neon, Railway, or Render.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/oncons

# UPI / QR payment setup.
# Put your UPI ID here so payments reach the bank account linked to that UPI ID.
UPI_ID=
UPI_PAYEE_NAME=OnCons
PAYMENT_QR_URL=/assets/img/payment-qr.jpeg
PAYMENT_AUTO_VERIFY_SECONDS=8

# Consultation billing.
CALL_FREE_MINUTES=5
CALL_RATE_PER_MINUTE=25
DETAILS_UNLOCK_AMOUNT=25
UPI_UTR_REGEX=^\d{12}$

# Expert booking email notifications.
# These must be filled for consultants to receive booking emails after the user confirms payment.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=your-email@gmail.com, SMTP_PASSWORD=your-app-password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=GOOGLE_APP_PASSWORD
FROM_EMAIL=
OTP_REQUIRE_EMAIL_DELIVERY=true

# Optional SMS webhook. Replace PUT_YOUR_FAST2SMS_API_KEY_HERE with your real Fast2SMS key.
SMS_WEBHOOK_URL=https://www.fast2sms.com/dev/bulkV2?authorization=PUT_YOUR_FAST2SMS_API_KEY_HERE&route=q&message={message}&language=english&flash=0&numbers={phone}

# Optional providers.
OPENAI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLOUDINARY_URL=
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=8
