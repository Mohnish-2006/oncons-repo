{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "OnCons: run from VS Code terminal",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File .\\run-vscode.ps1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Backend: run API",
      "type": "shell",
      "command": ".\\.venv312\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Frontend: run static server",
      "type": "shell",
      "command": "..\\backend\\.venv312\\Scripts\\python.exe -m http.server 5500",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "problemMatcher": [],
      "isBackground": true
    }
  ]
}
